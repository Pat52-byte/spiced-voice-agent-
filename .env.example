# ============================================================
# .env.example
# ============================================================

ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:password@host:5432/revops_db

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_MANAGER_CHANNEL=#revops-alerts
SLACK_SIGNING_SECRET=...     # per verificare webhook Slack

# Trascrizione (se Slack non fornisce trascrizione automatica)
OPENAI_API_KEY=sk-...        # usato solo per Whisper

# Call auto-capture (scegli uno: Recall.ai consigliato)
RECALL_API_KEY=...

# CRM
CRM_TYPE=salesforce          # oppure: hubspot
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com
SALESFORCE_ACCESS_TOKEN=...
HUBSPOT_API_KEY=pat-na1-...

COMPANY_DOMAIN=tuaazienda.com   # per distinguere meeting interni/esterni

PORT=3000
